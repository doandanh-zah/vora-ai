# VORA .env example
#
# Quick start:
# 1) Copy this file to `.env`
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
VORA_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Optional path overrides
# VORA_STATE_DIR=~/.vora
# VORA_CONFIG_PATH=~/.vora/vora.json
# VORA_HOME=~

# -----------------------------------------------------------------------------
# Model provider API keys
# VORA V1 uses ChatGPT Plus via OAuth — set this only for direct API fallback
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Channels (Telegram + Discord for V1)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...

# -----------------------------------------------------------------------------
# Web Search (Brave, Tavily, Exa)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# TAVILY_API_KEY=...
# EXA_API_KEY=...
